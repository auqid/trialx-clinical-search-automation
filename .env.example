# -----------------------------------------------------------------------------
# Environment contract for the Playwright suite.
# Copy this file to `.env` (which is gitignored) and adjust per environment.
#   cp .env.example .env
# playwright.config.js reads these via dotenv; nothing is hardcoded.
# -----------------------------------------------------------------------------

# Base URL the tests run against. Swap this to retarget dev / staging / prod.
BASE_URL=https://dev-connect.ainfo.io/clinical-trials/listings/

# Timeouts (milliseconds). Navigation/test budgets are generous because the
# shared dev server can be slow to load under parallel test load.
ACTION_TIMEOUT=15000        # per-action (click, fill, ...) timeout
NAVIGATION_TIMEOUT=60000    # per-navigation (goto, waitForURL) timeout
TEST_TIMEOUT=120000         # overall per-test timeout (must exceed navigation)
EXPECT_TIMEOUT=10000        # web-first assertion (expect) timeout
